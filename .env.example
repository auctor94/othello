# PostgreSQL — pick one URL depending on where the API runs.
# Omit DATABASE_URL entirely to use the in-memory store.

# API on host, Postgres in Docker (docker compose up db)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/reversi

# API in Docker Compose (hostname `db`; set in docker-compose.yml for the api service)
# DATABASE_URL=postgresql+psycopg://user:password@db:5432/reversi

# Comma-separated frontend origins allowed by CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
